# used for settings, copy to a file named .env and change/add values

# --- OpenAI ---
openai_api_key=
openai_model_name=gpt-4o-mini

# --- Azure OpenAI ---
azure_endpoint=https://your-azure-endpoint
azure_deployment_name=gpt-4o-mini
azure_api_version=2024-10-21
azure_api_key=

# --- Tavily (Web Search) ---
tavily_api_key=your-tavily-api-key

# --- Open Source Models ---
open_source_model_name=watt-ai/watt-tool-70B

# --- Embeddings ---
embeddings_model_name=text-embedding-ada-002
embeddings_api_version=2023-05-15
local_embeddings_model_name=all-MiniLM-L6-v2

# --- Anthropic (for Claude Agent SDK) ---
anthropic_api_key=

# --- Google (for Google ADK with Gemini) ---
google_api_key=
