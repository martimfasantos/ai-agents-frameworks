# Copy this file to .env and fill in the values
# Strands Agents SDK supports multiple model providers.
# The default provider is Amazon Bedrock (requires AWS credentials).

# --- AWS Credentials (for Amazon Bedrock, the default provider) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-west-2

# --- OpenAI (alternative provider) ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_NAME=gpt-4o-mini

# --- Anthropic (alternative provider) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
